{
  "files.exclude": {
      "**/*.pyc": {"when": "$(basename).py"},
      "**/__pycache__": true,
      "**/*.pytest_cache": true
  },
  "python.analysis.extraPaths": ["./.venv/Lib/site-packages"],
  "python.defaultInterpreterPath": "./.venv/Scripts/python.exe",
  "python.terminal.activateEnvironment": true
}
