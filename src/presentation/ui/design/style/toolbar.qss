QFrame#toolbar {
    background-color: $bg-toolbar;
}

QToolButton {
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 0px;
    font-family: $font-base;
    font-size: $fs-tb-md;
    color: $text-main;
    padding: 0px 18px;
    margin: 0px;
}

QToolButton:hover {
    background-color: $bg-toolbar-button-hover;
    color: $text-main;
    border: 1px solid transparent;
}

QToolButton:pressed {
    background-color: $bg-button-hover;
    color: $text-main;
}

QToolButton::menu-indicator {
    image: none;
    width: 0px;
}

QMenu {
    background-color: $bg-panel;
    border: 1px solid $border;
    border-radius: 0px;
    color: $text-main;
    padding: 0px;
}

QMenu::item {
    margin: 0px;
    padding: 10px 18px;
    border: 1px solid transparent;
    border-radius: 0px;
}

QMenu::item:selected {
    background-color: $bg-toolbar-button-hover;
    color: $text-main;
}

QMenu::item:checked {
    background-color: $bg-menu-item-checked;
    border: none;
    color: $text-main;
}

QMenu::indicator {
    image: none;
    width: 0px;
    height: 0px;
}

QMenu::separator {
    height: 0px;
    margin: 0;
    background: transparent;
}
